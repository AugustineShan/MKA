# ====================================================================
# ModelKing 环境变量配置
#   使用方法：复制本文件为 .env，填入你自己的凭证后保存，再双击 setup_and_run.cmd
#   （setup_and_run.cmd 首次运行若发现没有 .env，会自动复制并打开记事本让你填）
# ====================================================================

# ---------- TuShare（必填，三表取数用）----------
# 申请 token: https://tushare.pro/register  注册后在个人主页复制 token
TUSHARE_TOKEN=
# 数据接口地址，一般不用改
TUSHARE_HTTP_URL=http://api.waditu.com/dataapi
# 请求间隔(秒)，低于中转站限额即可
TUSHARE_MIN_INTERVAL_SECONDS=0.8

# ---------- LLM（年报核对 reconciler 用；不填则 LLM 自动补全不可用，rule-based 仍可用）----------
LLM_PROVIDER=glm

# 智谱 GLM: https://open.bigmodel.cn/  注册后控制台拿 API Key
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-5.2
GLM_TIMEOUT_SECONDS=300
# glm-5.2 是推理模型，会烧 reasoning_tokens 挤占 max_tokens 导致空返回。
# 这里都是"读报表上的数字"这类确定性任务，默认关 thinking：降延迟 ~3x 且避开截断陷阱。
# 仅对名字含 "5.2" 的模型生效；glm-5-turbo / glm-4-long 不受影响。
# 遇到难推断的科目再设 GLM_THINKING=enabled。
GLM_THINKING=disabled
LLM_MAX_TOKENS=32768
LLM_MAX_WORKERS=5

# ---------- Kimi fallback（可选，GLM 限流时兜底）----------
# https://platform.moonshot.cn/  申请 API Key
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6
KIMI_THINKING=disabled
