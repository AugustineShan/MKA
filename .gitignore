# ====================================================================
# 私人项目部署须知
#   .env       — TuShare / GLM 等凭证与配置，纳入版本控制（私人仓库，切勿转公开）
#   companies/ — 运行数据，体积大且含可再生二进制（PDF/db 等），不纳入版本控制
#                部署时凭 .env 用 data_fetcher / report_downloader / clean 重新生成
# ====================================================================

# Generated data directories
companies/
.recon/
annuals/

# ...but keep committed test fixtures even though annuals/ is ignored globally
!tests/fixtures/company_002946/annuals/
!tests/fixtures/company_002946/annuals/*

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Frontend
node_modules/
app/dist/
dist/

# Logs
*.log

# Worktrees
.worktrees/
worktrees/

# IDE / local config
# .claude/ holds project skills (skills/) that MUST be committed;
# ignore everything else under .claude/ (local settings, caches).
.claude/*
!.claude/skills/
.obsidian/
.serena/
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Temporary / draft docs
~$*
*.tmp
