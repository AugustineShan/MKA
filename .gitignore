# ====================================================================
# 私人项目部署须知
#   .env       — TuShare / GLM 等凭证，每人自己填，不纳入版本控制。
#                同事 clone 后双击 入口.cmd，会自动从 .env.example 复制并打开记事本。
#   companies/ — 默认不纳入版本控制（体积大、含可再生二进制 PDF/db）。
#                部署时凭 .env 用 data_fetcher / report_downloader / clean 重新生成。
# ====================================================================

# Credentials (each user fills their own)
.env

# Generated data directories
companies/*
.recon/
annuals/

# Temporary scratch / spreadsheet dumps (recon JSON, data.db copies, .xlsm)
tmp/

# Playwright MCP snapshots (regenerated each browser session)
.playwright-mcp/
.playwright-cli/

# Playwright test screenshots
output/playwright/

# ...but keep committed test fixtures even though annuals/ is ignored globally
!tests/fixtures/company_002946/annuals/
!tests/fixtures/company_002946/annuals/*

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/

# Frontend
node_modules/
# app/dist（前端构建产物）纳入版本控制：workbench 直接服务 app/dist/index.html，
# 缺失即报 "run npm run build first"，提交后 clone 即可 `py -m src.workbench` 开箱跑。

# Logs
*.log

# Worktrees
.worktrees/
worktrees/

# IDE / local config
# .claude/（项目 skills + 配置）整体纳入版本控制
.obsidian/
.serena/
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Temporary / draft docs
~$*
*.tmp

# GSD workflow planning state (personal, not project code)
.planning/
